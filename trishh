<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>TrishBite</title>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Fredoka+One&family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet"/>
  <style>
    :root {
      --red: #e63946; --yellow: #ffb703; --bg: #fff8f0;
      --border: #ecdfd5; --muted: #999; --shadow: rgba(180,80,30,0.10); --radius: 12px;
      --green: #2a9d5c;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Poppins', sans-serif; background: #e8e0d8; color: #1d1d1d; min-height: 100vh; display: flex; justify-content: center; align-items: flex-start; }
    #app { width: 100%; max-width: 480px; min-height: 100vh; background: var(--bg); box-shadow: 0 0 40px rgba(0,0,0,0.15); position: relative; overflow: hidden; }
    .screen { display: none; min-height: 100vh; flex-direction: column; animation: fadeUp .3s ease; }
    .screen.active { display: flex; }
    @keyframes fadeUp { from { opacity:0; transform:translateY(10px); } to { opacity:1; transform:none; } }

    /* ── TOPBAR ── */
    .topbar { background: var(--red); display: flex; align-items: center; justify-content: space-between; padding: 14px 18px; position: sticky; top: 0; z-index: 50; }
    .topbar-right { display: flex; align-items: center; gap: 8px; }
    .logo { font-family: 'Fredoka One', cursive; font-size: 1.5rem; color: #fff; }
    .logo span { color: var(--yellow); }
    .cart-pill { background: var(--yellow); border: none; border-radius: 30px; padding: 6px 16px; font-family: 'Poppins', sans-serif; font-weight: 700; font-size: .85rem; cursor: pointer; display: flex; align-items: center; gap: 6px; transition: transform .15s; }
    .cart-pill:hover { transform: scale(1.05); }
    .badge { background: var(--red); color: #fff; border-radius: 50%; width: 20px; height: 20px; font-size: .7rem; font-weight: 700; display: flex; align-items: center; justify-content: center; }
    .logout-btn { background: rgba(255,255,255,0.18); border: 1.5px solid rgba(255,255,255,0.45); color: #fff; border-radius: 30px; padding: 5px 13px; font-family: 'Poppins', sans-serif; font-weight: 600; font-size: .78rem; cursor: pointer; display: flex; align-items: center; gap: 5px; transition: background .18s, transform .15s; }
    .logout-btn:hover { background: rgba(255,255,255,.30); transform: scale(1.04); }
    .img-btn { background: rgba(255,255,255,0.18); border: 1.5px solid rgba(255,255,255,0.45); color: #fff; width: 34px; height: 34px; border-radius: 50%; font-size: 1rem; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: background .18s, transform .15s; flex-shrink: 0; }
    .img-btn:hover { background: rgba(255,255,255,.35); transform: scale(1.08); }
    .img-btn.help-btn { background: #fff; color: var(--red); border: none; font-weight: 700; font-size: .78rem; width: auto; padding: 0 12px; border-radius: 30px; font-family: 'Poppins', sans-serif; box-shadow: 0 2px 6px rgba(0,0,0,0.15); }
    .img-btn.help-btn:hover { background: #fff0f0; transform: scale(1.05); }

    /* ── FORMS ── */
    .input { width: 100%; padding: 11px 14px; border: 2px solid var(--border); border-radius: var(--radius); font-family: 'Poppins', sans-serif; font-size: .88rem; transition: border-color .2s; background: #fff; }
    .input:focus { outline: none; border-color: var(--red); }
    .input.error-field { border-color: var(--red); background: #fff5f5; }
    .form-row { margin-bottom: 12px; }
    .form-row label { font-size: .78rem; font-weight: 600; color: #555; display: block; margin-bottom: 5px; }
    .field-error { color: var(--red); font-size: .72rem; font-weight: 600; margin-top: 4px; display: none; }
    .field-error.show { display: block; }
    .pw-wrap { position: relative; }
    .pw-toggle { position: absolute; right: 12px; top: 50%; transform: translateY(-50%); background: none; border: none; cursor: pointer; font-size: 1rem; }
    .pw-strength { display: flex; align-items: center; gap: 8px; margin-top: 5px; }
    .pw-strength-bar { flex: 1; height: 4px; background: var(--border); border-radius: 4px; overflow: hidden; }
    .pw-strength-fill { height: 100%; border-radius: 4px; width: 0; transition: width .3s, background .3s; }
    .pw-strength-label { font-size: .7rem; color: var(--muted); font-weight: 600; white-space: nowrap; }
    .name-row { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 12px; }
    .terms-row { display: flex; align-items: flex-start; gap: 8px; margin-bottom: 12px; }
    .terms-row input { margin-top: 3px; accent-color: var(--red); }
    .terms-row label { font-size: .78rem; color: #555; line-height: 1.5; }
    .terms-row a { color: var(--red); text-decoration: none; font-weight: 600; }
    .auth-switch { text-align: center; font-size: .8rem; color: var(--muted); margin-top: 14px; }
    .auth-switch a { color: var(--red); font-weight: 700; cursor: pointer; }
    .forgot-link { text-align: right; margin: -6px 0 12px; }
    .forgot-link a { font-size: .78rem; color: var(--red); font-weight: 600; cursor: pointer; }
    .divider { display: flex; align-items: center; gap: 10px; text-align: center; color: var(--muted); font-size: .78rem; margin: 14px 0; }
    .divider::before, .divider::after { content: ''; flex: 1; height: 1px; background: rgba(255,255,255,.3); }
    .social-btns { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
    .social-btn { display: flex; align-items: center; justify-content: center; gap: 8px; padding: 10px; border-radius: var(--radius); border: none; background: var(--red); color: #fff; font-family: 'Poppins', sans-serif; font-weight: 600; font-size: .82rem; cursor: pointer; transition: background .18s, transform .15s; box-shadow: 0 2px 8px var(--shadow); }
    .social-btn:hover { background: #c1121f; transform: translateY(-1px); }
    .s-img { width: 20px; height: 20px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: .8rem; background: rgba(255,255,255,0.22); color: #fff; }
    .s-google .s-img { background: rgba(255,255,255,0.22); color: #fff; }
    .s-facebook .s-img { background: rgba(255,255,255,0.22); color: #fff; }

    /* ── LANDING / REGISTER CARDS ── */
    .landing-card, .register-card { background: rgba(255,255,255,.97); border-radius: 22px; padding: 28px 24px 24px; width: 100%; max-width: 380px; box-shadow: 0 8px 32px rgba(0,0,0,0.18); }
    .l-img { font-size: 3rem; display: block; text-align: center; margin-bottom: 6px; }
    .l-title { font-family: 'Fredoka One', cursive; font-size: 2rem; text-align: center; color: var(--red); margin-bottom: 2px; }
    .l-title span { color: #f4722a; }
    .l-sub { text-align: center; color: var(--muted); font-size: .82rem; margin-bottom: 20px; }
    .reg-header { text-align: center; margin-bottom: 18px; }
    .r-img { font-size: 2.5rem; display: block; margin-bottom: 6px; }
    .reg-header h2 { font-family: 'Fredoka One', cursive; font-size: 1.6rem; color: var(--red); }
    .reg-header p  { color: var(--muted); font-size: .8rem; margin-top: 2px; }
    .back-btn { background: rgba(255,255,255,.25); border: none; color: #fff; width: 34px; height: 34px; border-radius: 50%; font-size: 1.2rem; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: background .18s; }
    .back-btn:hover { background: rgba(255,255,255,.4); }

    /* ── FP / SL MODALS ── */
    .fp-overlay { position: fixed; inset: 0; background: rgba(0,0,0,.5); display: none; align-items: center; justify-content: center; z-index: 500; padding: 24px; }
    .fp-overlay.open { display: flex; }
    .fp-modal { background: #fff; border-radius: 18px; width: 100%; max-width: 360px; padding: 28px 24px 24px; text-align: center; animation: fadeUp .25s ease; box-shadow: 0 8px 32px rgba(0,0,0,0.18); }
    .fp-img { font-size: 2.5rem; display: block; margin-bottom: 10px; }
    .fp-modal h3 { font-family: 'Fredoka One', cursive; font-size: 1.4rem; color: #1d1d1d; margin-bottom: 6px; }
    .fp-modal p { color: var(--muted); font-size: .82rem; margin-bottom: 18px; line-height: 1.5; }
    .fp-btns { display: flex; gap: 8px; margin-top: 14px; }
    .fp-success { background: #e8f8ee; color: #2a9d5c; border: 1.5px solid #a8d5b8; border-radius: 8px; padding: 8px 12px; font-size: .8rem; font-weight: 600; margin-top: 10px; display: none; }
    .fp-success.show { display: block; }
    .sl-overlay { position: fixed; inset: 0; background: rgba(0,0,0,.5); display: none; align-items: center; justify-content: center; z-index: 500; padding: 24px; }
    .sl-overlay.open { display: flex; }
    .sl-modal { background: #fff; border-radius: 18px; width: 100%; max-width: 300px; padding: 28px 24px; text-align: center; animation: fadeUp .25s ease; }
    .sl-modal .spinner { margin: 0 auto 14px; }

    /* ── PROFILE MODAL ── */
    .profile-overlay { position: fixed; inset: 0; background: rgba(0,0,0,.5); display: none; align-items: flex-end; justify-content: center; z-index: 500; }
    .profile-overlay.open { display: flex; }
    .profile-modal { background: #fff; border-radius: 22px 22px 0 0; width: 100%; max-width: 480px; padding: 28px 24px 32px; animation: slideUp .25s ease; box-shadow: 0 -4px 32px rgba(0,0,0,0.15); max-height: 88vh; overflow-y: auto; }
    .profile-avatar { width: 72px; height: 72px; border-radius: 50%; background: linear-gradient(135deg, var(--red), #f4722a); display: flex; align-items: center; justify-content: center; color: #fff; margin: 0 auto 12px; font-family: 'Fredoka One', cursive; font-size: 1.8rem; }
    .profile-name { font-family: 'Fredoka One', cursive; font-size: 1.4rem; text-align: center; color: #1d1d1d; }
    .profile-email { text-align: center; color: var(--muted); font-size: .8rem; margin-bottom: 20px; }
    .profile-rows { background: var(--bg); border-radius: 14px; overflow: hidden; margin-bottom: 16px; }
    .profile-row { display: flex; align-items: center; gap: 12px; padding: 13px 16px; border-bottom: 1px solid var(--border); }
    .profile-row:last-child { border-bottom: none; }
    .profile-row .pr-img { font-size: 1.2rem; width: 28px; text-align: center; }
    .profile-row .pr-info { flex: 1; }
    .profile-row .pr-label { font-size: .72rem; color: var(--muted); font-weight: 600; }
    .profile-row .pr-val   { font-size: .85rem; font-weight: 600; color: #1d1d1d; }

    /* ── HELP MODAL ── */
    .help-overlay { position: fixed; inset: 0; background: rgba(0,0,0,.5); display: none; align-items: flex-end; justify-content: center; z-index: 500; }
    .help-overlay.open { display: flex; }
    .help-modal { background: #fff; border-radius: 22px 22px 0 0; width: 100%; max-width: 480px; padding: 28px 24px 32px; animation: slideUp .25s ease; max-height: 85vh; overflow-y: auto; }
    .help-modal .help-sub { text-align: center; color: var(--muted); font-size: .8rem; margin-bottom: 20px; }
    .help-step { display: flex; gap: 14px; align-items: flex-start; margin-bottom: 16px; }
    .help-step-num { width: 32px; height: 32px; border-radius: 50%; background: var(--red); color: #fff; font-family: 'Fredoka One', cursive; font-size: 1rem; display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-top: 2px; }
    .help-step-body .hs-title { font-weight: 700; font-size: .88rem; color: #1d1d1d; margin-bottom: 3px; }
    .help-step-body .hs-desc  { font-size: .78rem; color: var(--muted); line-height: 1.5; }

    /* ── MODALS ── */
    .logout-overlay { position: fixed; inset: 0; background: rgba(0,0,0,.5); display: none; align-items: center; justify-content: center; z-index: 500; }
    .logout-overlay.open { display: flex; }
    .logout-modal { background: #fff; border-radius: 18px; width: 88%; max-width: 340px; padding: 30px 24px 24px; text-align: center; animation: fadeUp .25s ease; box-shadow: 0 8px 32px rgba(0,0,0,0.18); }
    .logout-modal .lm-img { font-size: 2.8rem; display: block; margin-bottom: 10px; }
    .logout-modal h3 { font-family: 'Fredoka One', cursive; font-size: 1.4rem; color: #1d1d1d; margin-bottom: 6px; }
    .logout-modal p { color: var(--muted); font-size: .83rem; margin-bottom: 22px; line-height: 1.5; }
    .lm-btns { display: flex; gap: 10px; }
    .modal-x { position: absolute; top: 12px; right: 14px; background: #f0f0f0; border: none; width: 30px; height: 30px; border-radius: 50%; cursor: pointer; font-size: .9rem; display: flex; align-items: center; justify-content: center; color: #555; }
    .modal-x:hover { background: #e0e0e0; }

    /* ── BUTTONS ── */
    .btn { display: inline-flex; align-items: center; justify-content: center; gap: 6px; padding: 11px 24px; border-radius: var(--radius); border: none; font-family: 'Poppins', sans-serif; font-weight: 600; font-size: .9rem; cursor: pointer; transition: transform .15s, opacity .15s; box-shadow: 0 2px 8px var(--shadow); }
    .btn:hover { transform: translateY(-2px); }
    .btn:active { transform: none; }
    .btn-red   { background: var(--red); color: #fff; }
    .btn-ghost { background: transparent; color: var(--red); border: 2px solid var(--red); box-shadow: none; }
    .btn-green { background: var(--green); color: #fff; }
    .btn-yellow { background: var(--yellow); color: #1d1d1d; }
    .btn-block { width: 100%; }
    .btn-lg    { padding: 13px 28px; font-size: .95rem; }

    /* ── CATEGORY TABS ── */
    .cat-tabs { display: flex; overflow-x: auto; gap: 4px; padding: 12px 12px 0; background: #fff; border-bottom: 2px solid var(--border); scrollbar-width: none; }
    .cat-tabs::-webkit-scrollbar { display: none; }
    .cat-tab { display: flex; flex-direction: column; align-items: center; gap: 5px; padding: 0 10px 10px; border: none; background: none; cursor: pointer; font-family: 'Poppins', sans-serif; font-size: .7rem; font-weight: 600; color: var(--muted); white-space: nowrap; border-bottom: 2px solid transparent; flex-shrink: 0; transition: color .2s, border-color .2s; }
    .cat-tab .ct-img { width: 42px; height: 42px; border-radius: 14px; background: var(--bg); display: flex; align-items: center; justify-content: center; font-size: 1.4rem; transition: all .2s; box-shadow: 0 1px 4px var(--shadow); }
    .cat-tab:hover .ct-img { background: #ffe8e8; transform: translateY(-2px); }
    .cat-tab.active { color: var(--red); border-bottom-color: var(--red); }
    .cat-tab.active .ct-img { background: var(--red); box-shadow: 0 3px 10px rgba(230,57,70,0.35); }
    .cat-tab.active .ct-img span { filter: brightness(0) invert(1); }

    /* ── SEARCH BAR ── */
    .search-wrap { padding: 10px 12px; background: #fff; border-bottom: 1px solid var(--border); }
    .search-inner { display: flex; align-items: center; background: var(--bg); border: 2px solid var(--border); border-radius: 30px; padding: 8px 14px; gap: 8px; transition: border-color .2s; }
    .search-inner:focus-within { border-color: var(--red); }
    .search-inner span { color: var(--muted); font-size: 1rem; }
    .search-inner input { flex: 1; border: none; background: none; font-family: 'Poppins', sans-serif; font-size: .85rem; color: #1d1d1d; outline: none; }
    .search-clear { background: none; border: none; cursor: pointer; color: var(--muted); font-size: .9rem; display: none; }
    .search-clear.show { display: block; }

    /* ── MENU ── */
    .banner { background: linear-gradient(135deg, #e63946, #f4722a); color: #fff; padding: 14px 18px 12px; display: flex; align-items: center; justify-content: space-between; }
    .banner-text h2 { font-family: 'Fredoka One', cursive; font-size: 1.3rem; }
    .banner-text p  { font-size: .75rem; opacity: .85; margin-top: 2px; }
    .welcome-tag { background: rgba(255,255,255,.2); border-radius: 20px; padding: 4px 12px; font-size: .75rem; font-weight: 600; white-space: nowrap; }
    .menu-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; padding: 12px; }
    .menu-card { background: #fff; border-radius: var(--radius); overflow: hidden; box-shadow: 0 2px 8px var(--shadow); cursor: pointer; border: 2px solid transparent; transition: transform .2s, border-color .2s; position: relative; }
    .menu-card:hover { transform: translateY(-3px); border-color: var(--yellow); }
    .m-img  { height: 100px; background: linear-gradient(135deg,#fff6eb,#ffebd0); display: flex; align-items: center; justify-content: center; font-size: 3rem; position: relative; overflow: hidden; }
    .m-img img { width: 100%; height: 100%; object-fit: cover; display: block; }
    .m-img .img-placeholder { width: 100%; height: 100%; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 4px; background: linear-gradient(135deg,#f0e8df,#e8d8c8); color: #bba898; font-size: .65rem; font-weight: 600; letter-spacing: .03em; text-transform: uppercase; }
    .m-img .img-placeholder svg { opacity: .45; }
    .m-badge { position: absolute; top: 6px; left: 6px; background: var(--red); color: #fff; font-size: .6rem; font-weight: 700; padding: 2px 7px; border-radius: 20px; text-transform: uppercase; letter-spacing: .04em; }
    .m-badge.bestseller { background: var(--yellow); color: #1d1d1d; }
    .m-fav { position: absolute; top: 6px; right: 6px; background: rgba(255,255,255,.85); border: none; border-radius: 50%; width: 26px; height: 26px; cursor: pointer; font-size: .9rem; display: flex; align-items: center; justify-content: center; transition: transform .15s; }
    .m-fav:hover { transform: scale(1.2); }
    .m-body { padding: 8px 10px 10px; }
    .m-name { font-weight: 700; font-size: .85rem; }
    .m-desc { font-size: .7rem; color: var(--muted); margin: 2px 0 6px; line-height: 1.3; }
    .m-foot { display: flex; align-items: center; justify-content: space-between; }
    .m-price { font-family: 'Fredoka One', cursive; font-size: 1.1rem; color: var(--red); }
    .add-btn { background: var(--red); color: #fff; border: none; width: 28px; height: 28px; border-radius: 50%; font-size: 1.1rem; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: background .15s, transform .15s; }
    .add-btn:hover { background: #c1121f; transform: scale(1.1); }
    .no-results { text-align: center; padding: 40px 20px; color: var(--muted); grid-column: 1/-1; }
    .no-results span { font-size: 2.5rem; display: block; margin-bottom: 8px; }

    /* ── ITEM MODAL ── */
    .overlay { position: fixed; inset: 0; background: rgba(0,0,0,.5); display: none; align-items: flex-end; justify-content: center; z-index: 500; }
    .overlay.open { display: flex; }
    .modal { background: #fff; border-radius: 18px 18px 0 0; width: 100%; max-width: 460px; padding: 24px 20px 32px; position: relative; animation: slideUp .25s ease; max-height: 85vh; overflow-y: auto; }
    @keyframes slideUp { from { transform: translateY(28px); } to { transform: none; } }
    .m-emoji  { font-size: 3.5rem; display: block; text-align: center; margin-bottom: 8px; }
    .m-modal-img { width: 100%; height: 160px; border-radius: 14px; overflow: hidden; margin-bottom: 12px; background: linear-gradient(135deg,#f0e8df,#e8d8c8); display: flex; align-items: center; justify-content: center; }
    .m-modal-img img { width: 100%; height: 100%; object-fit: cover; display: block; }
    .m-modal-img .img-placeholder { width: 100%; height: 100%; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 6px; color: #bba898; font-size: .7rem; font-weight: 600; letter-spacing: .03em; text-transform: uppercase; }
    .m-modal-img .img-placeholder svg { opacity: .4; }
    .m-name-t { font-family: 'Fredoka One', cursive; font-size: 1.5rem; text-align: center; }
    .m-desc-t { text-align: center; color: var(--muted); font-size: .82rem; margin: 4px 0 16px; }
    .size-label { font-weight: 700; font-size: .78rem; color: #555; text-transform: uppercase; letter-spacing: .05em; margin-bottom: 8px; }
    .sizes { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 14px; }
    .sz-btn { padding: 7px 14px; border-radius: 8px; border: 2px solid var(--border); background: #fff; font-family: 'Poppins', sans-serif; font-weight: 600; font-size: .8rem; cursor: pointer; transition: all .15s; line-height: 1.4; }
    .sz-btn.on { border-color: var(--red); background: #fff5f5; color: var(--red); }
    .sz-price { display: block; font-size: .7rem; color: var(--muted); }
    .sz-btn.on .sz-price { color: var(--red); }
    .qty-row { display: flex; align-items: center; justify-content: space-between; background: var(--bg); border-radius: 10px; padding: 10px 14px; margin-bottom: 10px; }
    .qty-ctrl { display: flex; align-items: center; gap: 12px; }
    .q-btn { width: 32px; height: 32px; border-radius: 50%; border: 2px solid var(--border); background: #fff; font-size: 1rem; font-weight: 700; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: border-color .15s; }
    .q-btn:hover { border-color: var(--red); color: var(--red); }
    .q-num   { font-family: 'Fredoka One', cursive; font-size: 1.3rem; min-width: 22px; text-align: center; }
    .q-price { font-family: 'Fredoka One', cursive; font-size: 1.3rem; color: var(--red); }
    .special-note { margin-bottom: 14px; }
    .special-note label { font-size: .78rem; font-weight: 600; color: #555; display: block; margin-bottom: 5px; }
    .special-note textarea { width: 100%; border: 2px solid var(--border); border-radius: var(--radius); font-family: 'Poppins', sans-serif; font-size: .82rem; padding: 9px 12px; resize: none; height: 68px; transition: border-color .2s; }
    .special-note textarea:focus { outline: none; border-color: var(--red); }

    /* ── CART ── */
    .cart-hdr { background: var(--red); color: #fff; display: flex; align-items: center; gap: 10px; padding: 14px 18px; }
    .cart-hdr h2 { font-family: 'Fredoka One', cursive; font-size: 1.4rem; }
    .cart-body { padding: 14px; flex: 1; }
    .cart-item { background: #fff; border-radius: var(--radius); padding: 10px 12px; margin-bottom: 8px; display: flex; align-items: center; gap: 10px; box-shadow: 0 1px 6px var(--shadow); }
    .ci-ico { font-size: 1.9rem; width: 40px; text-align: center; }
    .ci-inf { flex: 1; }
    .ci-nm  { font-weight: 700; font-size: .85rem; }
    .ci-sz  { font-size: .72rem; color: var(--muted); }
    .ci-note { font-size: .68rem; color: #c47a00; font-style: italic; margin-top: 2px; }
    .ci-qty { display: flex; align-items: center; gap: 6px; margin-top: 3px; }
    .sq-btn { width: 22px; height: 22px; border-radius: 50%; border: 1.5px solid var(--border); background: #fff; font-size: .8rem; font-weight: 700; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: border-color .15s; }
    .sq-btn:hover { border-color: var(--red); color: var(--red); }
    .sq-num { font-weight: 700; font-size: .82rem; min-width: 16px; text-align: center; }
    .ci-pr  { font-family: 'Fredoka One', cursive; font-size: 1rem; color: var(--red); white-space: nowrap; }
    .ci-del { background: none; border: none; cursor: pointer; color: var(--muted); font-size: .95rem; transition: color .15s; }
    .ci-del:hover { color: var(--red); }
    .empty { text-align: center; padding: 50px 20px; color: var(--muted); }
    .empty .ei { font-size: 3rem; display: block; margin-bottom: 8px; }
    .empty p { font-weight: 600; }
    .promo-wrap { margin: 0 14px 10px; }
    .promo-inner { display: flex; gap: 8px; }
    .promo-inner input { flex: 1; }
    .promo-inner .btn { flex-shrink: 0; padding: 11px 16px; font-size: .82rem; }
    .promo-applied { background: #e8f8ee; color: #2a9d5c; border: 1.5px solid #a8d5b8; border-radius: 8px; padding: 8px 12px; font-size: .78rem; font-weight: 600; margin-top: 6px; display: none; }
    .promo-applied.show { display: block; }
    .summary { background: #fff; margin: 0 14px 12px; border-radius: var(--radius); padding: 14px; box-shadow: 0 1px 6px var(--shadow); }
    .s-row { display: flex; justify-content: space-between; font-size: .82rem; font-weight: 600; color: var(--muted); margin-bottom: 6px; }
    .s-row.tot { color: #1d1d1d; font-size: .9rem; font-weight: 700; border-top: 2px dashed var(--border); padding-top: 8px; margin-top: 2px; }
    .s-row.tot span:last-child { font-family: 'Fredoka One', cursive; font-size: 1.1rem; color: var(--red); }
    .s-row.disc { color: var(--green); }
    .cart-foot { padding: 0 14px 20px; display: flex; gap: 8px; }

    /* ── PAYMENT ── */
    .pay-hdr { background: var(--red); color: #fff; display: flex; align-items: center; gap: 10px; padding: 14px 18px; }
    .pay-hdr h2 { font-family: 'Fredoka One', cursive; font-size: 1.4rem; }
    .pay-body { padding: 14px; max-width: 460px; margin: 0 auto; }
    .recap { background: #fff; border-radius: var(--radius); padding: 14px; margin-bottom: 14px; box-shadow: 0 1px 6px var(--shadow); }
    .recap h4 { font-size: .78rem; font-weight: 700; color: #888; text-transform: uppercase; letter-spacing: .06em; margin-bottom: 8px; }
    .r-item { display: flex; justify-content: space-between; font-size: .82rem; font-weight: 600; margin-bottom: 5px; }
    .r-item span:last-child { color: var(--red); }
    .r-item.disc span:last-child { color: var(--green); }
    .r-tot  { display: flex; justify-content: space-between; font-weight: 700; font-size: .88rem; border-top: 1px dashed var(--border); padding-top: 8px; margin-top: 4px; }
    .r-tot span:last-child { font-family: 'Fredoka One', cursive; font-size: 1.05rem; color: var(--red); }
    .pay-methods h3 { font-weight: 700; font-size: .9rem; margin-bottom: 10px; }
    .pay-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; margin-bottom: 12px; }
    .pay-card { background: #fff; border-radius: var(--radius); padding: 14px 8px; border: 2px solid var(--border); text-align: center; cursor: pointer; transition: all .2s; box-shadow: 0 1px 6px var(--shadow); }
    .pay-card:hover, .pay-card.on { border-color: var(--red); background: #fff5f5; }
    .pay-card .pi { font-size: 1.6rem; display: block; margin-bottom: 4px; }
    .pay-card .pn { font-weight: 700; font-size: .78rem; }
    .pay-card.on .pn { color: var(--red); }
    .pay-detail { display: none; margin-bottom: 12px; }
    .pay-detail.show { display: block; }
    .cash-box { background: #fff; border-radius: var(--radius); padding: 16px; text-align: center; box-shadow: 0 1px 6px var(--shadow); }
    .cash-box p { color: var(--muted); font-size: .82rem; font-weight: 600; margin-bottom: 4px; }
    .cash-amt { font-family: 'Fredoka One', cursive; font-size: 2rem; color: var(--red); }

    /* ── PROCESSING ── */
    .proc { text-align: center; padding: 40px 20px; }
    .spinner { width: 60px; height: 60px; border: 5px solid var(--border); border-top-color: var(--red); border-radius: 50%; animation: spin .8s linear infinite; margin: 0 auto 18px; }
    @keyframes spin { to { transform: rotate(360deg); } }
    .proc h2 { font-family: 'Fredoka One', cursive; font-size: 1.6rem; }
    .proc p  { color: var(--muted); font-size: .85rem; margin-top: 4px; }
    #s-processing { align-items: stretch; justify-content: flex-start; }
    #s-processing .proc { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; }

    /* ── ORDER TRACKER ── */
    .tracker { background: #fff; margin: 14px 14px 0; border-radius: var(--radius); padding: 16px; box-shadow: 0 1px 6px var(--shadow); }
    .tracker h4 { font-size: .78rem; font-weight: 700; color: #888; text-transform: uppercase; letter-spacing: .06em; margin-bottom: 14px; }
    .track-steps { display: flex; align-items: center; justify-content: space-between; position: relative; }
    .track-steps::before { content: ''; position: absolute; top: 16px; left: 16px; right: 16px; height: 3px; background: var(--border); z-index: 0; }
    .track-fill { position: absolute; top: 16px; left: 16px; height: 3px; background: var(--green); z-index: 1; transition: width 1s ease; }
    .track-step { display: flex; flex-direction: column; align-items: center; gap: 6px; z-index: 2; }
    .ts-dot { width: 32px; height: 32px; border-radius: 50%; border: 3px solid var(--border); background: #fff; display: flex; align-items: center; justify-content: center; font-size: .9rem; transition: all .5s; }
    .ts-dot.done { background: var(--green); border-color: var(--green); color: #fff; }
    .ts-dot.active { background: var(--yellow); border-color: var(--yellow); animation: pulse 1.2s infinite; }
    @keyframes pulse { 0%,100%{transform:scale(1)}50%{transform:scale(1.12)} }
    .ts-label { font-size: .62rem; font-weight: 700; color: var(--muted); text-align: center; max-width: 52px; line-height: 1.3; }
    .ts-label.done, .ts-label.active { color: #1d1d1d; }

    /* ── RECEIPT ── */
    #s-receipt { background: var(--bg); align-items: center; padding: 0; }
    #s-receipt .receipt-wrap { padding: 16px; }
    .receipt-wrap { max-width: 400px; width: 100%; }
    .confirmed { background: #e8f8ee; color: #2a9d5c; border: 2px solid #a8d5b8; border-radius: 10px; padding: 10px 14px; font-weight: 700; font-size: .85rem; text-align: center; margin-bottom: 14px; }
    .paper { background: #fff; padding: 24px 20px; box-shadow: 0 4px 18px var(--shadow); position: relative; }
    .paper::before { content: ''; position: absolute; top: -7px; left: 0; right: 0; height: 8px; background: repeating-linear-gradient(-45deg,transparent,transparent 4px,#fff5f0 4px,#fff5f0 8px); }
    .paper::after  { content: ''; position: absolute; bottom: -7px; left: 0; right: 0; height: 8px; background: repeating-linear-gradient(45deg,transparent,transparent 4px,#fff5f0 4px,#fff5f0 8px); }
    .r-logo { font-family: 'Fredoka One', cursive; font-size: 1.5rem; color: var(--red); text-align: center; }
    .r-logo span { color: #f4722a; }
    .r-num-label { text-align: center; font-size: .7rem; font-weight: 700; color: var(--muted); text-transform: uppercase; letter-spacing: .1em; margin: 6px 0 2px; }
    .r-num-big   { font-family: 'Fredoka One', cursive; font-size: 2.8rem; color: #1d1d1d; text-align: center; line-height: 1; }
    .dash { border: none; border-top: 2px dashed var(--border); margin: 10px 0; }
    .r-row { display: flex; justify-content: space-between; font-size: .82rem; font-weight: 600; margin-bottom: 5px; }
    .r-row.tot { font-size: .9rem; font-weight: 700; border-top: 2px dashed var(--border); padding-top: 8px; margin-top: 4px; }
    .r-row.tot span:last-child { font-family: 'Fredoka One', cursive; font-size: 1.15rem; color: var(--red); }
    .r-meta { display: flex; justify-content: space-between; font-size: .75rem; font-weight: 600; color: var(--muted); }
    .r-footer { text-align: center; margin-top: 14px; }
    .r-footer .thanks { font-family: 'Fredoka One', cursive; font-size: 1.3rem; color: var(--red); display: block; }
    .r-footer p { font-size: .75rem; color: var(--muted); }
    .receipt-actions { display: flex; gap: 8px; margin-top: 18px; }

    /* ── ORDER HISTORY SCREEN ── */
    #s-history { background: var(--bg); }
    .hist-hdr { background: var(--red); color: #fff; display: flex; align-items: center; gap: 10px; padding: 14px 18px; }
    .hist-hdr h2 { font-family: 'Fredoka One', cursive; font-size: 1.4rem; }
    .hist-body { padding: 14px; flex: 1; }
    .hist-card { background: #fff; border-radius: var(--radius); padding: 14px; margin-bottom: 10px; box-shadow: 0 1px 6px var(--shadow); cursor: pointer; transition: transform .15s; }
    .hist-card:hover { transform: translateY(-2px); }
    .hist-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 6px; }
    .hist-num { font-family: 'Fredoka One', cursive; font-size: 1.1rem; color: var(--red); }
    .hist-date { font-size: .72rem; color: var(--muted); font-weight: 600; }
    .hist-items { font-size: .78rem; color: #555; margin-bottom: 8px; line-height: 1.5; }
    .hist-bot { display: flex; justify-content: space-between; align-items: center; }
    .hist-total { font-family: 'Fredoka One', cursive; font-size: 1.1rem; color: var(--red); }
    .hist-reorder { background: var(--yellow); border: none; border-radius: 20px; padding: 5px 14px; font-family: 'Poppins', sans-serif; font-weight: 700; font-size: .75rem; cursor: pointer; transition: transform .15s; }
    .hist-reorder:hover { transform: scale(1.05); }

    /* ── DARK MODE ── */
    body.dark { background: #1a1a1a; }
    body.dark #app { background: #121212; }
    body.dark .screen { background: #121212; }
    body.dark .landing-card, body.dark .register-card { background: rgba(30,30,30,.97); color: #f0f0f0; }
    body.dark .input { background: #2a2a2a; border-color: #444; color: #f0f0f0; }
    body.dark .input::placeholder { color: #666; }
    body.dark .form-row label, body.dark .terms-row label { color: #aaa; }
    body.dark .l-sub, body.dark .reg-header p { color: #888; }
    body.dark .menu-card, body.dark .cart-item, body.dark .summary, body.dark .recap, body.dark .pay-card, body.dark .paper, body.dark .hist-card, body.dark .tracker { background: #1e1e1e; color: #f0f0f0; }
    body.dark .m-img { background: linear-gradient(135deg,#2a2218,#332810); }
    body.dark .cat-tabs, body.dark .search-wrap { background: #1e1e1e; border-color: #333; }
    body.dark .search-inner { background: #2a2a2a; border-color: #444; }
    body.dark .search-inner input { color: #f0f0f0; }
    body.dark .cat-tab .ct-img { background: #2a2a2a; }
    body.dark .profile-modal, body.dark .help-modal, body.dark .logout-modal, body.dark .fp-modal, body.dark .sl-modal { background: #1e1e1e; color: #f0f0f0; }
    body.dark .profile-rows { background: #2a2a2a; }
    body.dark .profile-row { border-color: #333; }
    body.dark .profile-row .pr-val { color: #f0f0f0; }
    body.dark .banner { background: linear-gradient(135deg,#b02b36,#c45520); }
    body.dark .promo-applied { background: #1a3326; }
    body.dark .s-row { color: #aaa; }
    body.dark .s-row.tot { color: #f0f0f0; }
    body.dark .special-note textarea { background: #2a2a2a; border-color: #444; color: #f0f0f0; }
    body.dark .qty-row { background: #2a2a2a; }
    body.dark .sz-btn { background: #2a2a2a; border-color: #444; color: #f0f0f0; }
    body.dark .q-btn, body.dark .sq-btn { background: #2a2a2a; border-color: #444; color: #f0f0f0; }
    body.dark .modal { background: #1e1e1e; color: #f0f0f0; }
    body.dark .hist-hdr, body.dark .cart-hdr, body.dark .pay-hdr { background: #b02b36; }

    /* ── DARK TOGGLE BTN ── */
    .dark-toggle { background: none; border: 1.5px solid rgba(255,255,255,.45); color: #fff; width: 34px; height: 34px; border-radius: 50%; font-size: 1rem; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: background .18s; flex-shrink: 0; }
    .dark-toggle:hover { background: rgba(255,255,255,.2); }

    /* ── LOC / DELIVERY ── */
    .loc-btn { background: #fff; border: 2.5px solid var(--border); border-radius: 16px; padding: 18px 14px; display: flex; flex-direction: column; align-items: center; gap: 6px; cursor: pointer; transition: all .2s; box-shadow: 0 2px 8px var(--shadow); font-family: 'Poppins', sans-serif; }
    .loc-btn:hover, .loc-btn.active { border-color: var(--red); background: #fff5f5; transform: translateY(-2px); }
    .dm-card { background: #fff; border: 2.5px solid var(--border); border-radius: 14px; padding: 14px 16px; display: flex; align-items: center; gap: 14px; cursor: pointer; margin-bottom: 10px; transition: all .2s; box-shadow: 0 1px 6px var(--shadow); }
    .dm-card:hover, .dm-card.active { border-color: var(--red); background: #fff5f5; }
    .dm-img { font-size: 2rem; width: 44px; text-align: center; }
    .dm-info { flex: 1; }
    .dm-name { font-weight: 700; font-size: .88rem; }
    .dm-desc { font-size: .72rem; color: var(--muted); margin-top: 2px; }
    .dm-badge { background: #e8f8ee; color: #2a9d5c; font-size: .7rem; font-weight: 700; padding: 3px 10px; border-radius: 20px; white-space: nowrap; }
    .dm-badge.free { background: #e8f8ee; color: #2a9d5c; }

    /* ── TOAST ── */
    .toast { position: fixed; bottom: 18px; left: 50%; transform: translateX(-50%) translateY(70px); background: #222; color: #fff; padding: 9px 20px; border-radius: 30px; font-size: .82rem; font-weight: 600; z-index: 999; white-space: nowrap; transition: transform .3s ease; pointer-events: none; }
    .toast.show { transform: translateX(-50%) translateY(0); }

    @media print {
      body { background: #fff; }
      #app { box-shadow: none; max-width: 100%; }
      .screen { display: none !important; }
      #s-receipt { display: flex !important; }
      .receipt-actions, .confirmed { display: none !important; }
    }
  </style>
</head>
<body>
<div id="app">

  <!-- ══════════════════════════════════════════ LOGIN ══════════════════════════════════════════ -->
  <div id="s-landing" class="screen active">
    <div style="flex:1;display:flex;align-items:center;justify-content:center;padding:24px;background:var(--red);position:relative;overflow:hidden;">
      <div style="position:absolute;width:340px;height:340px;top:-100px;right:-100px;border-radius:50%;background:rgba(255,255,255,.05)"></div>
      <div style="position:absolute;width:220px;height:220px;bottom:-60px;left:-60px;border-radius:50%;background:rgba(255,255,255,.05)"></div>
      <div class="landing-card">
        <span class="l-img">🍔</span>
        <div class="l-title">Trish<span>Bite</span></div>
        <p class="l-sub">Fast. Fresh. Delicious.</p>
        <div class="form-row">
          <label>Email Address</label>
          <input class="input" id="login-email" type="email" placeholder="you@email.com" onkeydown="if(event.key==='Enter')login()"/>
          <p class="field-error" id="err-login-email">Please enter a valid email address.</p>
        </div>
        <div class="form-row">
          <label>Password</label>
          <div class="pw-wrap">
            <input class="input" id="login-pass" type="password" placeholder="••••••••" onkeydown="if(event.key==='Enter')login()"/>
            <button class="pw-toggle" type="button" onclick="togglePw('login-pass', this)">👁️</button>
          </div>
          <p class="field-error" id="err-login-pass">Incorrect password. Try again.</p>
        </div>
        <div class="forgot-link"><a onclick="openForgot()">Forgot Password?</a></div>
        <p class="field-error" id="err-login-general" style="text-align:center;margin-bottom:10px">No account found with that email.</p>
        <button class="btn btn-red btn-block btn-lg" onclick="login()">Login →</button>
        <div class="divider">or</div>
        <button class="btn btn-ghost btn-block" onclick="go('menu')">Continue as Guest 👤</button>
        <p class="auth-switch">Don't have an account? <a onclick="goRegister()">Create Account</a></p>
        <div class="divider" style="margin-top:14px">or continue with</div>
        <div class="social-btns">
          <button class="social-btn s-google" onclick="socialLogin('Google')"><span class="s-img">G</span> Google</button>
          <button class="social-btn s-facebook" onclick="socialLogin('Facebook')"><span class="s-img">f</span> Facebook</button>
        </div>
      </div>
    </div>
  </div>

  <!-- ══════════════════════════════════════════ REGISTER ══════════════════════════════════════════ -->
  <div id="s-register" class="screen">
    <div style="flex:1;display:flex;align-items:center;justify-content:center;padding:24px;background:var(--red);position:relative;overflow:hidden;">
      <div style="position:absolute;width:340px;height:340px;top:-100px;right:-100px;border-radius:50%;background:rgba(255,255,255,.05)"></div>
      <div style="position:absolute;width:220px;height:220px;bottom:-60px;left:-60px;border-radius:50%;background:rgba(255,255,255,.05)"></div>
      <div class="register-card">
        <div class="reg-header">
          <span class="r-img">✨</span>
          <h2>Create Account</h2>
          <p>Join TrishBite and start ordering!</p>
        </div>
        <div class="name-row">
          <div class="form-row" style="margin-bottom:0">
            <label>First Name</label>
            <input class="input" id="reg-fname" type="text" placeholder="Juan"/>
            <p class="field-error" id="err-fname">Required.</p>
          </div>
          <div class="form-row" style="margin-bottom:0">
            <label>Last Name</label>
            <input class="input" id="reg-lname" type="text" placeholder="dela Cruz"/>
            <p class="field-error" id="err-lname">Required.</p>
          </div>
        </div>
        <div class="form-row">
          <label>Email Address</label>
          <input class="input" id="reg-email" type="email" placeholder="you@email.com"/>
          <p class="field-error" id="err-reg-email">Please enter a valid email address.</p>
        </div>
        <div class="form-row">
          <label>Mobile Number</label>
          <input class="input" id="reg-phone" type="tel" placeholder="09XX XXX XXXX" maxlength="11"/>
          <p class="field-error" id="err-phone">Enter a valid PH mobile number (09XXXXXXXXX).</p>
        </div>
        <div class="form-row">
          <label>Password</label>
          <div class="pw-wrap">
            <input class="input" id="reg-pass" type="password" placeholder="Min. 6 characters" oninput="checkStrength(this.value)"/>
            <button class="pw-toggle" type="button" onclick="togglePw('reg-pass', this)">👁️</button>
          </div>
          <div class="pw-strength">
            <div class="pw-strength-bar"><div class="pw-strength-fill" id="str-bar"></div></div>
            <span class="pw-strength-label" id="str-label">Password strength</span>
          </div>
          <p class="field-error" id="err-reg-pass">Password must be at least 6 characters.</p>
        </div>
        <div class="form-row">
          <label>Confirm Password</label>
          <div class="pw-wrap">
            <input class="input" id="reg-cpass" type="password" placeholder="Re-enter password"/>
            <button class="pw-toggle" type="button" onclick="togglePw('reg-cpass', this)">👁️</button>
          </div>
          <p class="field-error" id="err-cpass">Passwords do not match.</p>
        </div>
        <div class="terms-row">
          <input type="checkbox" id="terms-check"/>
          <label for="terms-check">I agree to the <a href="#">Terms of Service</a> and <a href="#">Privacy Policy</a></label>
        </div>
        <p class="field-error" id="err-terms" style="margin-top:-8px;margin-bottom:10px">You must agree to the terms.</p>
        <button class="btn btn-red btn-block btn-lg" onclick="register()">Create Account 🎉</button>
        <p class="auth-switch" style="margin-top:12px">Already have an account? <a onclick="goLogin()">Login</a></p>
        <div class="divider" style="margin-top:14px">or sign up with</div>
        <div class="social-btns">
          <button class="social-btn s-google" onclick="socialLogin('Google')"><span class="s-img">G</span> Google</button>
          <button class="social-btn s-facebook" onclick="socialLogin('Facebook')"><span class="s-img">f</span> Facebook</button>
        </div>
      </div>
    </div>
  </div>

  <!-- ══════════════════════════════════════════ LOCATION ══════════════════════════════════════════ -->
  <div id="s-location" class="screen">
    <div class="topbar">
      <button class="back-btn" onclick="go('cart')">←</button>
      <div class="logo">Trish<span>Bite</span></div>
      <div style="width:34px"></div>
    </div>
    <div style="flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:28px 24px;background:linear-gradient(160deg,#fff8f0 60%,#ffe8dc);">
      <div style="text-align:center;margin-bottom:28px;">
        <div style="font-size:3.2rem;margin-bottom:10px;">📍</div>
        <h2 style="font-family:'Fredoka One',cursive;font-size:1.8rem;color:var(--red);margin-bottom:6px;">How are you ordering?</h2>
