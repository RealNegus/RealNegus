  // ── AUTH ─────────────────────────────────────────
  function login() {
    const email = $('login-email').value.trim();
    const pass  = $('login-pass').value.trim();
    let valid = true;
    clearAllErrors('err-login-email','err-login-pass','err-login-general');
    $('err-login-pass').textContent = 'Incorrect password. Try again.';
    $('err-login-general').textContent = 'No account found with that email.';
    $('login-email').classList.remove('error-field');
    $('login-pass').classList.remove('error-field');

    if (!email.includes('@') || !email.includes('.')) {
      setErr('err-login-email', true); $('login-email').classList.add('error-field'); valid = false;
    }
    if (!pass) {
      setErr('err-login-pass', true, 'Password is required.'); $('login-pass').classList.add('error-field'); valid = false;
    }
    if (!valid) return;

    const user = users.find(u => u.email.toLowerCase() === email.toLowerCase());
    if (!user) { setErr('err-login-general', true); $('login-email').classList.add('error-field'); return; }
    if (user.pass !== pass) { setErr('err-login-pass', true); $('login-pass').classList.add('error-field'); return; }

    currentUser = user;
    showToast('👋 Welcome back, ' + user.fname + '!');
    clearLoginForm();
    updateWelcome();
    go('menu');
  }

  function register() {
    const fname  = $('reg-fname').value.trim();
    const lname  = $('reg-lname').value.trim();
    const email  = $('reg-email').value.trim();
    const phone  = $('reg-phone').value.trim();
    const pass   = $('reg-pass').value.trim();
    const cpass  = $('reg-cpass').value.trim();
    const terms  = $('terms-check').checked;
    let valid = true;

    clearAllErrors('err-fname','err-lname','err-reg-email','err-phone','err-reg-pass','err-cpass','err-terms');
    ['reg-fname','reg-lname','reg-email','reg-phone','reg-pass','reg-cpass'].forEach(id => $(id).classList.remove('error-field'));

    if (!fname) { setErr('err-fname', true); $('reg-fname').classList.add('error-field'); valid = false; }
    if (!lname) { setErr('err-lname', true); $('reg-lname').classList.add('error-field'); valid = false; }
    if (!email.includes('@') || !email.includes('.')) { setErr('err-reg-email', true); $('reg-email').classList.add('error-field'); valid = false; }
    else if (users.find(u => u.email.toLowerCase() === email.toLowerCase())) {
      setErr('err-reg-email', true, 'This email is already registered.'); $('reg-email').classList.add('error-field'); valid = false;
    }
    if (!/^09\d{9}$/.test(phone)) { setErr('err-phone', true); $('reg-phone').classList.add('error-field'); valid = false; }
    if (pass.length < 6) { setErr('err-reg-pass', true); $('reg-pass').classList.add('error-field'); valid = false; }
    if (pass !== cpass) { setErr('err-cpass', true); $('reg-cpass').classList.add('error-field'); valid = false; }
    if (!terms) { setErr('err-terms', true); valid = false; }
    if (!valid) return;

    const newUser = { email, pass, fname, lname, phone, since: new Date().toLocaleDateString('en-PH',{month:'long',year:'numeric'}) };
    users.push(newUser);
    saveUsers();
    currentUser = newUser;
    showToast('🎉 Account created! Welcome, ' + fname + '!');
    clearRegForm();
    updateWelcome();
    go('menu');
  }

