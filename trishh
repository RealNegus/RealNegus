  function buildMenuGrid(catId, query = '') {
    const grid = $('menu-grid');
    let entries = Object.entries(ITEMS);
    if (catId === 'favs') {
      entries = entries.filter(([k]) => favorites.includes(k));
    } else if (catId !== 'all') {
      entries = entries.filter(([, v]) => v.cat === catId);
    }
    if (query) {
      entries = entries.filter(([, v]) => v.name.toLowerCase().includes(query.toLowerCase()));
    }
    if (!entries.length) {
      grid.innerHTML = `<div class="no-results"><span>😔</span><p>${query ? 'No results for "'+query+'"' : 'No favorites yet! Tap ❤️ on items.'}</p></div>`;
      return;
    }
    grid.innerHTML = entries.map(([key, it]) => {
      const isFav = favorites.includes(key);
      const badgeHtml = it.badge && BADGE_COLORS[it.badge]
        ? `<span class="m-badge" style="${BADGE_COLORS[it.badge]}">${it.badge}</span>` : '';
      return `
