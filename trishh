<script>
  // ── HELPERS ──────────────────────────────────────
  const $ = id => document.getElementById(id);
  function setErr(id, show, msg) {
    const el = $(id);
    el.classList.toggle('show', show);
    if (msg) el.textContent = msg;
  }
  function clearAllErrors(...ids) { ids.forEach(id => { const el=$(id); if(el){el.classList.remove('show');} }); }

  let toastTimer;
  function showToast(msg) {
    const t = $('toast');
    t.textContent = msg;
    t.classList.add('show');
    clearTimeout(toastTimer);
    toastTimer = setTimeout(() => t.classList.remove('show'), 2500);
  }

  function togglePw(id, btn) {
    const inp = $(id);
    inp.type = inp.type === 'password' ? 'text' : 'password';
    btn.textContent = inp.type === 'password' ? '👁️' : '🙈';
  }

  function checkStrength(val) {
    const bar = $('str-bar'), lbl = $('str-label');
    let score = 0;
    if (val.length >= 6) score++;
    if (val.length >= 10) score++;
    if (/[A-Z]/.test(val) && /[a-z]/.test(val)) score++;
    if (/\d/.test(val)) score++;
    if (/[^a-zA-Z0-9]/.test(val)) score++;
    const levels = [
      { pct:'20%', color:'#e63946', label:'Weak' },
      { pct:'40%', color:'#f4722a', label:'Fair' },
      { pct:'65%', color:'#ffb703', label:'Good' },
      { pct:'80%', color:'#57cc99', label:'Strong' },
      { pct:'100%',color:'#2a9d5c', label:'Very Strong' }
    ];
    const lvl = levels[Math.min(score, 4)];
    bar.style.width = lvl.pct;
    bar.style.background = lvl.color;
    lbl.textContent = val ? lvl.label : 'Password strength';
    lbl.style.color = val ? lvl.color : 'var(--muted)';
  }

  function go(id) {
    document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
    $('s-' + id).classList.add('active');
    window.scrollTo(0, 0);
  }

  function goRegister() { clearRegForm(); go('register'); }
  function goLogin() { clearLoginForm(); go('landing'); }

  function clearLoginForm() {
    ['login-email','login-pass'].forEach(id => { $(id).value = ''; $(id).classList.remove('error-field'); });
    clearAllErrors('err-login-email','err-login-pass','err-login-general');
  }

  function clearRegForm() {
    ['reg-fname','reg-lname','reg-email','reg-phone','reg-pass','reg-cpass'].forEach(id => {
      $(id).value = ''; $(id).classList.remove('error-field');
    });
    $('terms-check').checked = false;
    $('str-bar').style.width = '0';
    $('str-label').textContent = 'Password strength';
    clearAllErrors('err-fname','err-lname','err-reg-email','err-phone','err-reg-pass','err-cpass','err-terms');
  }

  // ── STATE ────────────────────────────────────────
  let users = JSON.parse(localStorage.getItem('trishbite_users') || '[]');
  let orderHistory = JSON.parse(localStorage.getItem('trishbite_history') || '[]');
  let currentUser = null;
  let locType = null;
  let deliveryMethod = null;
  let cart = [];
  let payMethod = null;
  let modalState = { key: null, sizeIdx: 0, qty: 1 };
  let activeCategory = 'all';
  let favorites = JSON.parse(localStorage.getItem('trishbite_favs') || '[]');
  let promoDiscount = 0;
