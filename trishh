    const imgDiv = $('m-modal-img');
    if (it.img) {
      imgDiv.innerHTML = `<img src="${it.img}" alt="${it.name}"/>`;
    } else {
      imgDiv.innerHTML = `<div class="img-placeholder"><svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2"><rect x="3" y="3" width="18" height="18" rx="3"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg><span>${it.name}</span></div>`;
    }
    $('m-name').textContent  = it.name;
    $('m-desc').textContent  = it.desc;
    $('m-notes').value       = '';
    renderSizes(); updatePrice();
    $('modal').classList.add('open');
  }
  function closeModal() { $('modal').classList.remove('open'); }
  function renderSizes() {
    $('m-sizes').innerHTML = ITEMS[modalState.key].sizes.map((s,i)=>`
      <button class="sz-btn ${i===modalState.sizeIdx?'on':''}" onclick="pickSize(${i})">
        ${s.label}<span class="sz-price">₱${s.price}</span>
      </button>`).join('');
  }
  function pickSize(i)  { modalState.sizeIdx=i; renderSizes(); updatePrice(); }
  function changeQty(d) { modalState.qty=Math.max(1,modalState.qty+d); $('m-qty').textContent=modalState.qty; updatePrice(); }
  function updatePrice() {
    const p = ITEMS[modalState.key].sizes[modalState.sizeIdx].price * modalState.qty;
    $('m-price').textContent = '₱'+p.toLocaleString();
  }
  function addToCart() {
    const { key, sizeIdx, qty } = modalState;
    const it=ITEMS[key], sz=it.sizes[sizeIdx];
    const note = $('m-notes').value.trim();
    cart.push({ id:Date.now(), emoji:it.emoji, name:it.name, size:sz.label, unitPrice:sz.price, qty, note });
    updateBadge(); closeModal();
    showToast(it.emoji+' '+it.name+' added!');
  }
  function quickAdd(key) {
    const it=ITEMS[key], sz=it.sizes[0];
    cart.push({ id:Date.now(), emoji:it.emoji, name:it.name, size:sz.label, unitPrice:sz.price, qty:1, note:'' });
    updateBadge();
    showToast(it.emoji+' '+it.name+' added!');
  }
  function updateBadge() { $('cart-count').textContent=cart.reduce((s,i)=>s+i.qty,0); }

  // ── PROMO ─────────────────────────────────────────
  function applyPromo() {
    const code = $('promo-input').value.trim().toUpperCase();
    const promo = PROMOS[code];
    if (!promo) { showToast('❌ Invalid promo code'); $('promo-msg').classList.remove('show'); promoDiscount=0; promoCode=''; renderCart(); return; }
    promoCode = code; promoDiscount = 0; // recalc on renderCart
    $('promo-msg').textContent = '✅ ' + promo.label;
    $('promo-msg').classList.add('show');
    renderCart();
    showToast('🎉 Promo applied!');
  }

  // ── CART ─────────────────────────────────────────
  function goCart() { renderCart(); go('cart'); }
  function renderCart() {
    const body=$('cart-body'), sum=$('cart-summary'), btn=$('checkout-btn');
    if (!cart.length) {
      body.innerHTML='<div class="empty"><span class="ei">🛒</span><p>Cart is empty</p></div>';
      sum.innerHTML=''; btn.disabled=true; btn.style.opacity='.5';
      $('promo-msg').classList.remove('show'); return;
    }
    btn.disabled=false; btn.style.opacity='1';
    body.innerHTML=cart.map(ci=>`
      <div class="cart-item">
        <div class="ci-ico">${ci.emoji}</div>
        <div class="ci-inf">
          <div class="ci-nm">${ci.name}</div>
          <div class="ci-sz">${ci.size}</div>
          ${ci.note?`<div class="ci-note">📝 ${ci.note}</div>`:''}
          <div class="ci-qty">
            <button class="sq-btn" onclick="cQty(${ci.id},-1)">−</button>
            <span class="sq-num">${ci.qty}</span>
            <button class="sq-btn" onclick="cQty(${ci.id},1)">+</button>
          </div>
        </div>
        <span class="ci-pr">₱${(ci.unitPrice*ci.qty).toLocaleString()}</span>
        <button class="ci-del" onclick="removeItem(${ci.id})">🗑️</button>
      </div>`).join('');
    const { sub, tax, del, disc, tot } = calcTotal();
    sum.innerHTML=`
      <div class="s-row"><span>Subtotal</span><span>₱${sub.toLocaleString()}</span></div>
      <div class="s-row"><span>VAT (12%)</span><span>₱${tax.toFixed(2)}</span></div>
      ${del?`<div class="s-row"><span>Delivery Fee</span><span>₱${del}</span></div>`:''}
      ${disc?`<div class="s-row disc"><span>Discount (${promoCode})</span><span>−₱${disc.toFixed(2)}</span></div>`:''}
      <div class="s-row tot"><span>Total</span><span>₱${tot.toFixed(2)}</span></div>`;
  }
  function cQty(id,d) {
    const it=cart.find(i=>i.id===id);
    if (it) it.qty=Math.max(1,it.qty+d);
    updateBadge(); renderCart();
  }
  function removeItem(id) { cart=cart.filter(i=>i.id!==id); updateBadge(); renderCart(); }

  function calcTotal() {
    const sub = cart.reduce((s,i)=>s+(i.unitPrice*i.qty),0);
    const tax = sub * 0.12;
    const del = locType==='delivery' ? (promoCode==='FREESHIP'?0:49) : 0;
    let disc = 0;
    if (promoCode && PROMOS[promoCode]) {
      const p = PROMOS[promoCode];
      if (p.type==='pct')  disc = (sub+tax) * p.value / 100;
      if (p.type==='flat') disc = p.value;
    }
    const tot = Math.max(0, sub+tax+del-disc);
    return { sub, tax, del, disc, tot };
  }

  // ── PAYMENT ──────────────────────────────────────
  function goPayment() {
    if (!cart.length) return showToast('Cart is empty!');
    locType=null; deliveryMethod=null;
    $('lb-delivery').classList.remove('active');
    $('lb-pickup').classList.remove('active');
    $('addr-wrap').style.display='none';
    $('address').value='';
    go('location');
  }

  function goPaymentFinal() {
    payMethod=null;
    PAYS.forEach(m=>{ $('pm-'+m).classList.remove('on'); $('detail-'+m).classList.remove('show'); });
    const { sub, tax, del, disc, tot } = calcTotal();
    const sel = DELIVERY_METHODS[locType]?.find(m=>m.id===deliveryMethod);
    const mLabel = sel ? sel.img+' '+sel.name : '';
    $('recap').innerHTML=`
      <h4>Order Summary</h4>
      ${cart.map(ci=>`<div class="r-item"><span>${ci.qty}× ${ci.name} (${ci.size})</span><span>₱${(ci.unitPrice*ci.qty).toLocaleString()}</span></div>`).join('')}
      <div class="r-item" style="color:var(--muted)"><span>${locType==='delivery'?'🛵 Delivery':'🏃 Pick-up'} · ${mLabel}</span><span>${del?'₱'+del:'Free'}</span></div>
      ${disc?`<div class="r-item disc"><span>Discount (${promoCode})</span><span>−₱${disc.toFixed(2)}</span></div>`:''}
      <div class="r-tot"><span>Total</span><span>₱${tot.toFixed(2)}</span></div>`;
    $('cash-amt').textContent='₱'+tot.toFixed(2);
    go('payment');
  }

  function selectPay(m) {
    payMethod=m;
    PAYS.forEach(p=>{ $('pm-'+p).classList.toggle('on',p===m); $('detail-'+p).classList.toggle('show',p===m); });
  }

  function placeOrder() {
    if (!payMethod) return showToast('Please select a payment method');
    if (payMethod==='gcash'   && $('gcash-num').value.replace(/\D/g,'').length<10) return showToast('Enter a valid GCash number');
    if (payMethod==='paymaya' && $('paymaya-num').value.replace(/\D/g,'').length<10) return showToast('Enter a valid PayMaya number');
    go('processing');
    setTimeout(buildReceipt, 2000);
  }

  // ── RECEIPT & TRACKER ────────────────────────────
  function buildReceipt() {
    const { sub, tax, del, disc, tot } = calcTotal();
    const orderNum = '#' + Math.floor(1000+Math.random()*9000);
    $('r-num').textContent = orderNum;
    $('r-items').innerHTML = cart.map(ci=>`
      <div class="r-row">
        <span>${ci.qty}× ${ci.emoji} ${ci.name} <small style="color:#aaa">(${ci.size})</small></span>
        <span>₱${(ci.unitPrice*ci.qty).toLocaleString()}</span>
      </div>`).join('');
    $('r-totals').innerHTML=`
      <div class="r-row"><span>Subtotal</span><span>₱${sub.toLocaleString()}</span></div>
      <div class="r-row"><span>VAT (12%)</span><span>₱${tax.toFixed(2)}</span></div>
      ${del?`<div class="r-row"><span>Delivery</span><span>₱${del}</span></div>`:''}
      ${disc?`<div class="r-row" style="color:var(--green)"><span>Discount</span><span>−₱${disc.toFixed(2)}</span></div>`:''}
      <div class="r-row tot"><span>TOTAL</span><span>₱${tot.toFixed(2)}</span></div>`;
    $('r-pay').textContent = PAY_LABELS[payMethod];
    $('r-loc').textContent = locType==='delivery'?'🛵 Delivery':'🏃 Pick-up';

    // Save to history
    const histEntry = {
      num: orderNum,
      date: new Date().toLocaleDateString('en-PH',{month:'short',day:'numeric',year:'numeric'}),
      time: new Date().toLocaleTimeString('en-PH',{hour:'2-digit',minute:'2-digit'}),
      items: cart.map(ci=>({...ci})),
      tot, sub, tax, del, disc,
      payMethod, locType
    };
    orderHistory.unshift(histEntry);
    if (orderHistory.length > 20) orderHistory.pop();
    saveHistory();

    // Update tracker label for pickup
    if (locType==='pickup') {
      $('tsl3').textContent='Ready'; $('tsl4').textContent='Picked Up';
    } else {
      $('tsl3').textContent='On the Way'; $('tsl4').textContent='Delivered';
    }

    go('receipt');
    startTracker();
  }

  let trackerStep = 1;
  function startTracker() {
    trackerStep = 1;
    $('ts1').className='ts-dot done'; $('ts2').className='ts-dot active';
    $('ts3').className='ts-dot'; $('ts4').className='ts-dot';
    $('track-fill').style.width = '0%';
    const steps = [
      { delay:3000,  fill:'33%', done:'ts2', active:'ts3' },
      { delay:8000,  fill:'66%', done:'ts3', active:'ts4' },
      { delay:14000, fill:'100%',done:'ts4', active:null  },
    ];
    steps.forEach(s => {
      setTimeout(()=>{
        if (s.done) { const d=$(s.done); if(d){d.className='ts-dot done'; d.textContent='✓';} }
        if (s.active) { const a=$(s.active); if(a){ a.className='ts-dot active'; } }
        $('track-fill').style.width = s.fill;
        if (!s.active) showToast(locType==='delivery'?'🎉 Order delivered!':'✅ Order ready for pick-up!');
      }, s.delay);
    });
  }

  function newOrder() {
    cart=[]; payMethod=null; locType=null; promoDiscount=0; promoCode='';
    $('promo-input').value=''; $('promo-msg').classList.remove('show');
    updateBadge(); go('menu');
  }

  // ── ORDER HISTORY ─────────────────────────────────
  function renderHistory() {
    const body = $('hist-body');
    if (!orderHistory.length) {
      body.innerHTML='<div class="empty"><span class="ei">📋</span><p>No orders yet</p></div>'; return;
    }
    body.innerHTML = orderHistory.map((o,i)=>`
      <div class="hist-card">
        <div class="hist-top">
          <span class="hist-num">${o.num}</span>
          <span class="hist-date">${o.date} · ${o.time}</span>
        </div>
        <div class="hist-items">${o.items.map(ci=>ci.qty+'× '+ci.name).join(', ')}</div>
        <div class="hist-bot">
          <span class="hist-total">₱${o.tot.toFixed(2)}</span>
          <button class="hist-reorder" onclick="reorder(${i})">🔄 Reorder</button>
        </div>
      </div>`).join('');
  }

  function reorder(idx) {
    const o = orderHistory[idx];
    o.items.forEach(ci => {
      cart.push({ id:Date.now()+Math.random(), emoji:ci.emoji, name:ci.name, size:ci.size, unitPrice:ci.unitPrice, qty:ci.qty, note:'' });
    });
    updateBadge();
    go('menu');
    showToast('🛒 Items added to cart!');
  }

  function go(id) {
    document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));
    $('s-'+id).classList.add('active');
    window.scrollTo(0,0);
    if (id==='history') renderHistory();
  }
</script>
</body>
</html>
